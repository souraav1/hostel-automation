{
  "name": "hostel-management-system",
  "version": "1.0.0",
  "description": "A full-stack hostel automation system for college",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "client": "cd client && npm run dev",
    "seed": "node scripts/seed.js",
    "client-install": "cd client && npm install",
    "dev-full": "concurrently \"npm run dev\" \"npm run client\"",
    "build": "cd client && npm run build",
    "heroku-postbuild": "npm run client-install && npm run build"
  },
  "keywords": ["hostel", "management", "mern", "college"],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0"
  }
}